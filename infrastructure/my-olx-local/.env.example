# Backend env vars for local development — copy to backend/.env

DATABASE_URL=postgres://postgres:password@localhost:5432/my_olx
REDIS_URL=redis://localhost:6379

# LocalStack S3 — use fake credentials and point to local endpoint
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=eu-central-1
AWS_S3_BUCKET=my-olx-uploads
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

JWT_SECRET=change-me-in-development
JWT_EXPIRY_SECONDS=86400

HOST=0.0.0.0
PORT=8080
RUST_LOG=my_olx_backend=debug,tower_http=debug
